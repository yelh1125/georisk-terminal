# PostgreSQL (required for durable historical storage in production)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/georisk?schema=public"

# Redis (optional; API responses fall back to an in-process cache)
REDIS_URL="redis://localhost:6379"

# Official data providers
FRED_API_KEY="your_fred_api_key"
ALPHA_VANTAGE_API_KEY="optional_key_for_full_SPY_history"
# Recommended independent high-frequency news fallback when GDELT is rate-limited.
NEWS_API_KEY="optional_newsapi_org_key_for_headline_count_and_sentiment"
CBOE_API_URL="https://cdn.cboe.com/api/global/delayed_quotes/quotes/VIX.json"

# Optional: direct, dated Excel URL downloaded from the official GPR page.
# When omitted, the official AI-GPR daily CSV is the default geopolitical-risk source.
GPR_DAILY_XLS_URL=""

# Optional API protection for POST /api/risk/update
CRON_SECRET="replace-with-a-long-random-value"

# Real series are fetched from public official CSV/XLSX sources. No mock-data fallback is used.
